<!-- Version 1.0.2 -->
{% if current_site.display_powered_by_link? == false %}
  <style>
    #section-footer {
      -webkit-box-flex: 1;
      -ms-flex-positive: 1;
      flex-grow: 1;
      display: -webkit-box;
      display: -ms-flexbox;
      display: flex;
    }
    .footer {
      -webkit-box-flex: 1;
      -ms-flex-positive: 1;
      flex-grow: 1;
    }
  </style>
{% endif %}
<style>
  .footer {
    background-color: {{ section.settings.background_color }};
  }
  .footer, .footer__block {
    font-size: {{ section.settings.font_size_mobile }};
    color: {{ section.settings.text_color }};
  }
  .footer .logo__text {
    color: {{ section.settings.logo_text_color }};
  }
  .footer .link-list__links {
    width: 100%;
  }
  .footer a.link-list__link {
    color: {{ section.settings.text_color }};
  }
  .footer .link-list__link:hover {
    color: {{ section.settings.text_color }};
  }
  .copyright {
    color: {{ section.settings.copyright_text_color }};
  }
  @media (min-width: 768px) {
    .footer, .footer__block {
      font-size: {{ section.settings.font_size_desktop }};
    }
  }
  .powered-by a {
    color: {{ section.settings.powered_by_text_color }} !important;
  }
  {% if section.settings.vertical_layout == true %}
    .powered-by {
      text-align: center;
      padding-top: 0;
    }
  {% endif %}

  /* === CUSTOM SOCIAL ICON BLOCK === */
  .footer .footer__block--custom-social {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .footer .custom-social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .footer .custom-social-icon:hover {
    opacity: 0.75;
    transform: translateY(-1px);
  }
  .footer .custom-social-icon svg {
    display: block;
    width: 100%;
    height: 100%;
    fill: currentColor;
  }
  .footer .custom-social-icon img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .footer .custom-social-icon--round {
    border-radius: 50%;
    padding: 8px;
  }
  .footer .custom-social-icon--square {
    border-radius: 6px;
    padding: 8px;
  }
</style>

<footer class="footer {% if section.settings.vertical_layout == true %}footer--stacked{% endif %} {% if section.settings.background_color != blank %} background-{{ section.settings.background_color | color_scheme_class }}{% endif %} {% if section.settings.hide_on_desktop %}hidden--desktop{% endif %} {% if section.settings.hide_on_mobile %}hidden--mobile{% endif %}" kjb-settings-id="{{ 'background_color' | settings_id: section: section }}">
  <div class="footer__content">
    <div class="container footer__container media">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when "logo" %}
            {% include "footer_block" type:"shared_block_logo" %}
          {% when "link_list" %}
            {% include "block" type: "link_list", placement: "section" %}
          {% when "copyright" %}
            {% include "footer_block" type:"footer_block_copyright" %}
          {% when "social_icons" %}
            {% include "footer_block" type:"footer_block_social_icons" %}
          {% when "custom_social_icon" %}
            {% if block.settings.icon_link != blank %}
              {% assign icon_size = block.settings.icon_size | default: 32 %}
              {% assign icon_color = block.settings.icon_color %}
              {% assign bg_style = block.settings.bg_style %}
              {% assign bg_color = block.settings.bg_color %}
              {% assign preset = block.settings.icon_preset %}

              <div class="footer__block footer__block--custom-social">
                <a href="{{ block.settings.icon_link }}" 
                   class="custom-social-icon{% if bg_style == 'round' %} custom-social-icon--round{% elsif bg_style == 'square' %} custom-social-icon--square{% endif %}"
                   style="width: {{ icon_size }}px; height: auto;{% if icon_color != blank %} color: {{ icon_color }};{% else %} color: #727272;{% endif %}{% if bg_style != '' and bg_color != blank %} background-color: {{ bg_color }};{% endif %}"
                   aria-label="{{ block.settings.icon_alt | escape }}"
                   {% if block.settings.new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                  
                  {% if preset == 'instagram' %}
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 2.16094C15.2063 2.16094 15.5859 2.175 16.8469 2.23125C18.0188 2.28281 18.6516 2.47969 19.0734 2.64375C19.6313 2.85938 20.0344 3.12188 20.4516 3.53906C20.8734 3.96094 21.1313 4.35938 21.3469 4.91719C21.5109 5.33906 21.7078 5.97656 21.7594 7.14375C21.8156 8.40937 21.8297 8.78906 21.8297 11.9906C21.8297 15.1969 21.8156 15.5766 21.7594 16.8375C21.7078 18.0094 21.5109 18.6422 21.3469 19.0641C21.1313 19.6219 20.8687 20.025 20.4516 20.4422C20.0297 20.8641 19.6313 21.1219 19.0734 21.3375C18.6516 21.5016 18.0141 21.6984 16.8469 21.75C15.5813 21.8062 15.2016 21.8203 12 21.8203C8.79375 21.8203 8.41406 21.8062 7.15313 21.75C5.98125 21.6984 5.34844 21.5016 4.92656 21.3375C4.36875 21.1219 3.96563 20.8594 3.54844 20.4422C3.12656 20.0203 2.86875 19.6219 2.65313 19.0641C2.48906 18.6422 2.29219 18.0047 2.24063 16.8375C2.18438 15.5719 2.17031 15.1922 2.17031 11.9906C2.17031 8.78438 2.18438 8.40469 2.24063 7.14375C2.29219 5.97187 2.48906 5.33906 2.65313 4.91719C2.86875 4.35938 3.13125 3.95625 3.54844 3.53906C3.97031 3.11719 4.36875 2.85938 4.92656 2.64375C5.34844 2.47969 5.98594 2.28281 7.15313 2.23125C8.41406 2.175 8.79375 2.16094 12 2.16094ZM12 0C8.74219 0 8.33438 0.0140625 7.05469 0.0703125C5.77969 0.126563 4.90313 0.332812 4.14375 0.628125C3.35156 0.9375 2.68125 1.34531 2.01563 2.01562C1.34531 2.68125 0.9375 3.35156 0.628125 4.13906C0.332812 4.90313 0.126563 5.775 0.0703125 7.05C0.0140625 8.33437 0 8.74219 0 12C0 15.2578 0.0140625 15.6656 0.0703125 16.9453C0.126563 18.2203 0.332812 19.0969 0.628125 19.8563C0.9375 20.6484 1.34531 21.3188 2.01563 21.9844C2.68125 22.65 3.35156 23.0625 4.13906 23.3672C4.90313 23.6625 5.775 23.8687 7.05 23.925C8.32969 23.9812 8.7375 23.9953 11.9953 23.9953C15.2531 23.9953 15.6609 23.9812 16.9406 23.925C18.2156 23.8687 19.0922 23.6625 19.8516 23.3672C20.6391 23.0625 21.3094 22.65 21.975 21.9844C22.6406 21.3188 23.0531 20.6484 23.3578 19.8609C23.6531 19.0969 23.8594 18.225 23.9156 16.95C23.9719 15.6703 23.9859 15.2625 23.9859 12.0047C23.9859 8.74688 23.9719 8.33906 23.9156 7.05938C23.8594 5.78438 23.6531 4.90781 23.3578 4.14844C23.0625 3.35156 22.6547 2.68125 21.9844 2.01562C21.3188 1.35 20.6484 0.9375 19.8609 0.632812C19.0969 0.3375 18.225 0.13125 16.95 0.075C15.6656 0.0140625 15.2578 0 12 0Z"/>
                      <path d="M12 5.83594C8.59688 5.83594 5.83594 8.59688 5.83594 12C5.83594 15.4031 8.59688 18.1641 12 18.1641C15.4031 18.1641 18.1641 15.4031 18.1641 12C18.1641 8.59688 15.4031 5.83594 12 5.83594ZM12 15.9984C9.79219 15.9984 8.00156 14.2078 8.00156 12C8.00156 9.79219 9.79219 8.00156 12 8.00156C14.2078 8.00156 15.9984 9.79219 15.9984 12C15.9984 14.2078 14.2078 15.9984 12 15.9984Z"/>
                      <path d="M19.8469 5.5922C19.8469 6.38908 19.2 7.03127 18.4078 7.03127C17.6109 7.03127 16.9688 6.38439 16.9688 5.5922C16.9688 4.79533 17.6156 4.15314 18.4078 4.15314C19.2 4.15314 19.8469 4.80001 19.8469 5.5922Z"/>
                    </svg>
                  {% elsif preset == 'substack' %}
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
                    </svg>
                  {% elsif preset == 'youtube' %}
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path d="m10 15l5.19-3L10 9zm11.56-7.83c.13.47.22 1.1.28 1.9c.07.8.1 1.49.1 2.09L22 12c0 2.19-.16 3.8-.44 4.83c-.25.9-.83 1.48-1.73 1.73c-.47.13-1.33.22-2.65.28c-1.3.07-2.49.1-3.59.1L12 19c-4.19 0-6.8-.16-7.83-.44c-.9-.25-1.48-.83-1.73-1.73c-.13-.47-.22-1.1-.28-1.9c-.07-.8-.1-1.49-.1-2.09L2 12c0-2.19.16-3.8.44-4.83c.25-.9.83-1.48 1.73-1.73c.47-.13 1.33-.22 2.65-.28c1.3-.07 2.49-.1 3.59-.1L12 5c4.19 0 6.8.16 7.83.44c.9.25 1.48.83 1.73 1.73"/>
                    </svg>
                  {% elsif preset == 'linkedin' %}
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path d="M20.47 2H3.53a1.45 1.45 0 0 0-1.47 1.43v17.14A1.45 1.45 0 0 0 3.53 22h16.94a1.45 1.45 0 0 0 1.47-1.43V3.43A1.45 1.45 0 0 0 20.47 2M8.09 18.74h-3v-9h3ZM6.59 8.48a1.56 1.56 0 1 1 0-3.12a1.57 1.57 0 1 1 0 3.12m12.32 10.26h-3v-4.83c0-1.21-.43-2-1.52-2A1.65 1.65 0 0 0 12.85 13a2 2 0 0 0-.1.73v5h-3v-9h3V11a3 3 0 0 1 2.71-1.5c2 0 3.45 1.29 3.45 4.06Z"/>
                    </svg>
                  {% elsif preset == 'custom' and block.settings.icon_image != blank %}
                    <img src="{{ block.settings.icon_image | image_picker_url: 'default' }}" alt="{{ block.settings.icon_alt | escape }}">
                  {% endif %}
                </a>
              </div>
            {% endif %}
        {% endcase %}
      {% endfor %}
    </div>
    {% include "global_powered_by" %}
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "elements": [
    {
      "type": "select",
      "id": "font_size_desktop",
      "label": "Font size desktop",
      "default": "18px",
      "preset": "font_sizes",
      "options": []
    },
    {
      "type": "select",
      "id": "font_size_mobile",
      "label": "Font size mobile",
      "default": "16px",
      "preset": "font_sizes",
      "options": []
    },
    {
      "type": "color",
      "label": "Footer text",
      "id": "text_color",
      "default": "",
      "allow_blank": true
    },
    {
      "type": "color",
      "label": "Copyright text",
      "id": "copyright_text_color",
      "default": "",
      "allow_blank": true
    },
    {
      "type": "color",
      "label": "Powered by Kajabi text",
      "id": "powered_by_text_color",
      "default": "",
      "allow_blank": true
    },
    {
      "type": "color",
      "label": "Footer background",
      "id": "background_color",
      "default": ""
    }
  ],
  "groups": [
    {
      "name": "Desktop layout",
      "elements": [
        {
          "type": "checkbox",
          "id": "hide_on_desktop",
          "label": "Hide footer",
          "default": "false"
        },
        {
          "type": "checkbox",
          "id": "vertical_layout",
          "label": "Vertical layout",
          "default": "false",
          "info": "Switch to a stacked layout."
        }
      ]
    },
    {
      "name": "Mobile layout",
      "elements": [
        {
          "type": "checkbox",
          "id": "hide_on_mobile",
          "label": "Hide footer",
          "default": "false"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "elements": [
        {
          "type": "header",
          "content": "Logo"
        },
        {
          "type": "pill_tabs",
          "id": "logo_type",
          "label": "Logo type",
          "default": "image",
          "options": [
            { "label": "Image", "value": "image" },
            { "label": "Text", "value": "text" },
            { "label": "SVG",   "value": "svg"   }
          ]
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image",
          "fit": "max",
          "width": 1000,
          "height": 1000,
          "info": "Suggested dimensions: 360x80",
          "default": "",
          "default_global_settings_attribute": "brand.logo",
          "hide_if": { "logo_type": ["text", "svg"] }
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Alt text",
          "default": "Footer Logo",
          "hide_if": { "logo_type": ["text", "svg"] }
        },
        {
          "type": "text",
          "id": "logo_width",
          "label": "Logo image width",
          "default": "50",
          "hide_if": { "logo_type": ["text", "svg"] }
        },
        {
          "type": "text",
          "id": "logo_text",
          "label": "Logo text",
          "default": "Encore",
          "hide_if": { "logo_type": ["image", "svg"] }
        },
        {
          "type": "color",
          "label": "Logo text color",
          "id": "logo_text_color",
          "default": "",
          "allow_blank": true,
          "hide_if": { "logo_type": ["image", "svg"] }
        },
        {
          "type": "textarea",
          "id": "logo_svg",
          "label": "SVG code",
          "default": "",
          "info": "Paste your raw SVG markup here.",
          "hide_if": {
            "logo_type": ["image", "text"]
          }
        },
        {
          "type": "text",
          "id": "logo_svg_width",
          "label": "SVG width (px)",
          "default": "120",
          "hide_if": {
            "logo_type": ["image", "text"]
          }
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Link List",
      "groups": [
        {
          "name": "Desktop layout",
          "elements": [
            {
              "type": "align",
              "id": "text_align",
              "label": "Text alignment",
              "default": "right",
              "direction": "horizontal"
            }
          ]
        },
        {
          "name": "Mobile layout",
          "elements": [
            {
              "type": "align",
              "id": "mobile_text_align",
              "label": "Text alignment",
              "default": "center",
              "direction": "horizontal"
            }
          ]
        }
      ],
      "elements": [
        {
          "type": "header",
          "content": "Link List"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "info": "Secondary navigation for your site",
          "default": "main-menu"
        },
        {
          "type": "color",
          "id": "link_color",
          "label": "Link color",
          "allow_blank": "true"
        },
        {
          "type": "pill_tabs",
          "id": "vertical",
          "label": "Vertical alignment",
          "default": "row",
          "options": [
            {
              "value": "row",
              "label": "Row"
            },
            {
              "value": "column",
              "label": "Column"
            }
          ]
        },
        {
          "type": "checkbox",
          "id": "new_tab",
          "label": "Open new tab",
          "default": "false"
        }
      ]
    },
    {
      "type": "copyright",
      "name": "Copyright",
      "elements": [
        {
          "type": "header",
          "content": "Copyright"
        },
        {
          "type": "text",
          "id": "copyright",
          "label": "Copyright",
          "default": "Kajabi"
        }
      ]
    },
    {
      "type": "social_icons",
      "name": "Social Icons",
      "elements": [
        {
          "type": "header",
          "content": "Social icons"
        },
        {
          "type": "checkbox",
          "id": "new_tab",
          "label": "Open new tab",
          "default": "false"
        },
        {
          "type": "color",
          "label": "Social icon",
          "id": "social_icons_text_color",
          "allow_blank": true,
          "info": "Change the color for the social icons."
        },
        {
          "type": "color",
          "label": "Background",
          "id": "social_icons_background_color",
          "allow_blank": true,
          "info": "Change the background color for the social icon containers."
        },
        {
          "type": "pill_tabs",
          "id": "social_icon_background_style",
          "label": "Background style",
          "default": "",
          "options": [
            { "label": "Round", "value": "round" },
            { "label": "Square", "value": "square" },
            { "label": "None", "value": "" }
          ]
        },
        {
          "type": "text",
          "id": "social_icon_link_facebook",
          "label": "Facebook",
          "default": "",
          "default_global_settings_attribute": "brand.social.facebook"
        },
        {
          "type": "text",
          "id": "social_icon_link_twitter",
          "label": "X",
          "default": "",
          "default_global_settings_attribute": "brand.social.x"
        },
        {
          "type": "text",
          "id": "social_icon_link_instagram",
          "label": "Instagram",
          "default": "",
          "default_global_settings_attribute": "brand.social.instagram"
        },
        {
          "type": "text",
          "id": "social_icon_link_youtube",
          "label": "YouTube",
          "default": "",
          "default_global_settings_attribute": "brand.social.youtube"
        },
        {
          "type": "text",
          "id": "social_icon_link_pinterest",
          "label": "Pinterest",
          "default": ""
        },
        {
          "type": "text",
          "id": "social_icon_link_vimeo",
          "label": "Vimeo",
          "default": ""
        },
        {
          "type": "text",
          "id": "social_icon_link_github",
          "label": "Github",
          "default": ""
        },
        {
          "type": "text",
          "id": "social_icon_link_itunes",
          "label": "iTunes",
          "default": ""
        },
        {
          "type": "text",
          "id": "social_icon_link_linkedin",
          "label": "LinkedIn",
          "default": "",
          "default_global_settings_attribute": "brand.social.linkedin"
        },
        {
          "type": "text",
          "id": "social_icon_link_soundcloud",
          "label": "Soundcloud",
          "default": ""
        },
        {
          "type": "text",
          "id": "social_icon_link_yelp",
          "label": "Yelp",
          "default": ""
        },
        {
          "type": "text",
          "id": "social_icon_link_tumblr",
          "label": "Tumblr",
          "default": ""
        },
        {
          "type": "text",
          "id": "social_icon_link_slack",
          "label": "Slack",
          "default": ""
        },
        {
          "type": "text",
          "id": "social_icon_link_flickr",
          "label": "Flickr",
          "default": ""
        },
        {
          "type": "text",
          "id": "social_icon_link_dribbble",
          "label": "Dribbble",
          "default": ""
        },
        {
          "type": "text",
          "id": "social_icon_link_tiktok",
          "label": "TikTok",
          "default": "",
          "default_global_settings_attribute": "brand.social.tiktok"
        },
        {
          "type": "text",
          "id": "social_icon_link_medium",
          "label": "Medium",
          "default": ""
        },
        {
          "type": "text",
          "id": "social_icon_link_spotify",
          "label": "Spotify",
          "default": ""
        },
        {
          "type": "text",
          "id": "social_icon_link_podcasts",
          "label": "Podcasts",
          "default": ""
        }
      ]
    },
    {
      "type": "custom_social_icon",
      "name": "New Social Icon",
      "elements": [
        {
          "type": "header",
          "content": "Custom Social Icon"
        },
        {
          "type": "select",
          "id": "icon_preset",
          "label": "Icon Type",
          "default": "instagram",
          "options": [
            { "label": "Instagram", "value": "instagram" },
            { "label": "Substack",  "value": "substack"  },
            { "label": "YouTube",   "value": "youtube"   },
            { "label": "LinkedIn",  "value": "linkedin"  },
            { "label": "Custom Upload", "value": "custom" }
          ]
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Upload Icon (SVG/PNG)",
          "info": "Only used when 'Custom Upload' is selected above."
        },
        {
          "type": "text",
          "id": "icon_alt",
          "label": "Alt Text",
          "default": "Social media link"
        },
        {
          "type": "text",
          "id": "icon_link",
          "label": "Link URL",
          "info": "Icon won't show if this is empty. Must include https://",
          "default": "https://"
        },
        {
          "type": "checkbox",
          "id": "new_tab",
          "label": "Open link in new tab?",
          "default": "true"
        },
        {
          "type": "header",
          "content": "Styling",
          "style": "subheading"
        },
        {
          "type": "range",
          "id": "icon_size",
          "label": "Icon Size (px)",
          "default": "32",
          "min": "16",
          "max": "64",
          "step": "2"
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "Icon Color",
          "default": "#727272",
          "allow_blank": true,
          "info": "Only applies to preset SVG icons."
        },
        {
          "type": "pill_tabs",
          "id": "bg_style",
          "label": "Background Style",
          "default": "",
          "options": [
            { "label": "None", "value": "" },
            { "label": "Round", "value": "round" },
            { "label": "Square", "value": "square" }
          ]
        },
        {
          "type": "color",
