<!-- Start Version 1.10.0 -->
{% assign spacing_classes = '' %}
{% if section.settings.margin_top != 'none' %}{% assign spacing_classes = spacing_classes | append: ' mt-' | append: section.settings.margin_top %}{% endif %}
{% if section.settings.margin_bottom != 'none' %}{% assign spacing_classes = spacing_classes | append: ' mb-' | append: section.settings.margin_bottom %}{% endif %}
{% if section.settings.padding_top != 'none' %}{% assign spacing_classes = spacing_classes | append: ' pt-' | append: section.settings.padding_top %}{% endif %}
{% if section.settings.padding_bottom != 'none' %}{% assign spacing_classes = spacing_classes | append: ' pb-' | append: section.settings.padding_bottom %}{% endif %}

<style>
    #section-header header.header {
        background: #FFF9EB;
        backdrop-filter: unset;
    }
    
    /* === SCOPED CSS === */
    .pm-book-promo-{{ section.id }} {
        position: relative;
        z-index: 1;
        box-sizing: border-box;
    }

    .pm-book-promo-{{ section.id }} * {
        box-sizing: border-box;
    }

    .pm-book-promo-{{ section.id }} .container {
        max-width: 100%;
        margin: 0 auto;
        padding: 0;
    }

    /* === SHOWCASE GRID === */
    .pm-book-promo-{{ section.id }} .showcase-wrapper {
        width: 100%;
        background-color: #FFF9EB;
        padding-block: 136px 114px;
        margin-bottom: 104px;
    }
    
    .pm-book-promo-{{ section.id }} .showcase-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 200px;
        width: 100%;
        max-width: 1280px;
        margin-inline: auto;
        position: relative;
    }

    .pm-book-promo-{{ section.id }} .book-img-wrap {
        position: absolute;
        left: 50%;
        top: -84px;
        transform: translateX(-50%);
        z-index: 2;
    }

    .pm-book-promo-{{ section.id }} .book-img {
        max-width: 400px;
        width: 100%;
    }

    /* === SIDE REVIEWS === */
    .pm-book-promo-{{ section.id }} .side-review {
        text-align: center;
        max-width: 280px;
        margin: 0 auto;
    }

    .pm-book-promo-{{ section.id }} .side-review > svg {
        margin-bottom: 4px;
    }

    .pm-book-promo-{{ section.id }} .review-text {
        font-family: var(--pm-font-heading);
        font-size: 16px;
        color: {{ section.settings.review_text_color }};
        line-height: 1.4em;
        margin-bottom: 12px;
    }

    .pm-book-promo-{{ section.id }} .review-author-info {
        width: 100%;
        max-width: 216px;
        margin-inline: auto;
    }
    
    .pm-book-promo-{{ section.id }} .review-author {
        font-family: var(--pm-font-body);
        font-size: 13px;
        font-weight: 400;
        line-height: 1.4em;
        color: {{ section.settings.heading_color }};
        margin: 0;
    }

    .pm-book-promo-{{ section.id }} .review-source {
        font-family: var(--pm-font-body);
        font-size: 12px;
        line-height: 1.4em;
        font-weight: 400;
        color: {{ section.settings.source_color }};
        margin: 0;
    }

    /* === MAIN CONTENT AREA === */
    .pm-book-promo-{{ section.id }} .main-content {
        max-width: 880px;
        margin: 0 auto;
        text-align: center;
    }

    /* Group 1: Rating Line */
    .pm-book-promo-{{ section.id }} .content-group-rating {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 7px;
        margin-bottom: 12px;
    }

    .pm-book-promo-{{ section.id }} .rating-text-wrap {
        display: flex;
        align-items: end;
        justify-content: center;
        gap: 7px;
    }

    .pm-book-promo-{{ section.id }} .main-rating-text {
        font-family: var(--pm-font-heading);
        font-size: 14px;
        font-weight: 400;
        line-height: 1.4;
        color: {{ section.settings.text_color }};
        margin: 0;
        padding-bottom: 4px;
    }

    .pm-book-promo-{{ section.id }} .platform-logo {
        height: 18px;
        width: auto;
        display: block;
    }

    /* Group 2: Title & Description */
    .pm-book-promo-{{ section.id }} .content-group-text {
        display: flex;
        flex-direction: column;
        gap: 24px;
        margin-bottom: 32px;
    }

    .pm-book-promo-{{ section.id }} .dynamic-title {
        color: {{ section.settings.heading_color }};
        margin: 0 auto;
        width: 100%;
        max-width: 600px;
    }

    .pm-book-promo-{{ section.id }} .desc-text {
        font-family: var(--pm-font-heading);
        font-size: 18px;
        color: #484848;
        line-height: 1.4;
        margin: 0;
        font-weight: 400;
        width: 100%;
        max-width: 435px;
        margin-inline: auto;
    }

    /* Group 3: CTA & Highlight */
    .pm-book-promo-{{ section.id }} .content-group-cta {
        display: flex;
        flex-direction: column;
        align-items: center;
        /* gap: 20px; */
    }

    .pm-book-promo-{{ section.id }} .highlight-text {
        font-family: var(--pm-font-heading);
        font-size: 16px;
        font-weight: 600;
        line-height: 1.4;
        color: {{ section.settings.highlight_color }};
        margin: 0;
        width: 100%;
        max-width: 280px;
        margin-inline: auto;
    }
    
    .pm-book-promo-{{ section.id }} .highlight-text + .btn {
        margin: 0;
    }
    
    .pm-book-promo-{{ section.id }} .cta-buttons-wrap {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 33px;
    }
    
    .pm-book-promo-{{ section.id }} .cta-buttons-wrap .btn {
        margin: 0;
    }
    
    @media (max-width: 1440px) {
        .pm-book-promo-{{ section.id }} .main-wrapper,
        .pm-book-promo-{{ section.id }} .showcase-wrapper {
            padding-inline: 32px;
        }
    }

    /* === RESPONSIVE === */
    @media (max-width: 1024px) {
        .pm-book-promo-{{ section.id }} .side-review {
            display: none;
        }
        
        .pm-book-promo-{{ section.id }} .showcase-wrapper {
            padding-block: 128px 280px;
        }
        
        .pm-book-promo-{{ section.id }} .content-group-text {
            gap: 12px;
            margin-bottom: 24px;
        }
        
        .pm-book-promo-{{ section.id }} .dynamic-title {
            max-width: 540px;
        }
        
        .pm-book-promo-{{ section.id }} .book-img {
            width: 340px;
        }
        
        .pm-book-promo-{{ section.id }} .cta-buttons-wrap {
            flex-direction: column;
            gap: 12px;
        }
    }
    
    @media (max-width: 600px) {
        .pm-book-promo-{{ section.id }} .main-wrapper,
        .pm-book-promo-{{ section.id }} .showcase-wrapper {
            padding-inline: 16px;
        }
        
        .pm-book-promo-{{ section.id }} .showcase-wrapper {
            padding-block: 32px 410px;
            margin-bottom: 40px;
        }
        
        .pm-book-promo-{{ section.id }} .showcase-grid {
            display: flex;
            justify-content: center;
            gap: 0;
        }
        
        .pm-book-promo-{{ section.id }} .book-img-wrap {
            left: auto;
            top: 12px;
            transform: none;
        }
        
        .pm-book-promo-{{ section.id }} .book-img {
            width: 100%;
            max-width: 336px;
        }
        
        .pm-book-promo-{{ section.id }} .dynamic-title {
            max-width: 320px;
        }
    }
</style>

