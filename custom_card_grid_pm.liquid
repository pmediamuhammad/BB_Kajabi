{% schema %}
{
  "name": "Card Grid - PM",
  "elements": [
    {
      "type": "header",
      "content": "Section Heading (Optional)"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": ""
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": ""
    },
    {
      "type": "select",
      "id": "section_title_tag",
      "label": "Section Title HTML Tag (SEO)",
      "default": "h2",
      "options": [
        { "label": "Heading 1 (H1)", "value": "h1" },
        { "label": "Heading 2 (H2)", "value": "h2" },
        { "label": "Heading 3 (H3)", "value": "h3" },
        { "label": "Heading 4 (H4)", "value": "h4" },
        { "label": "Paragraph (P)", "value": "p" }
      ]
    },
    {
      "type": "select",
      "id": "section_title_style_class",
      "label": "Section Title Visual Style",
      "default": "",
      "options": [
        { "label": "Default (No Extra Class)", "value": "" },
        { "label": "Heading 1 Style (.h1)", "value": "h1" },
        { "label": "Heading 2 Style (.h2)", "value": "h2" },
        { "label": "Heading 3 Style (.h3)", "value": "h3" },
        { "label": "Heading 4 Style (.h4)", "value": "h4" },
        { "label": "Text XL (.text-xl)", "value": "text-xl" },
        { "label": "Text Large (.text-lg)", "value": "text-lg" },
        { "label": "Text Medium (.text-md)", "value": "text-md" },
        { "label": "Text Small (.text-sm)", "value": "text-sm" }
      ]
    },
    {
      "type": "rich_text",
      "id": "section_desc",
      "label": "Section Description",
      "default": ""
    },
    {
      "type": "select",
      "id": "section_desc_style_class",
      "label": "Section Description Visual Style",
      "info": "Optional class for description text size. Leave Default to use global styles.",
      "default": "",
      "options": [
        { "label": "Default (No Extra Class)", "value": "" },
        { "label": "Text XL (.text-xl)", "value": "text-xl" },
        { "label": "Text Large (.text-lg)", "value": "text-lg" },
        { "label": "Text Medium (.text-md)", "value": "text-md" },
        { "label": "Text Small (.text-sm)", "value": "text-sm" }
      ]
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Section Heading Alignment",
      "info": "Alignment for the section subtitle, title, and description above the cards.",
      "default": "left",
      "options": [
