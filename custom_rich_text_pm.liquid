<!-- Start Version 1.10.2 -->
{% comment %} === AUTO-DETECT: if no main image, force text-only centered layout === {% endcomment %}
{% if section.settings.main_img != blank %}
  {% assign effective_layout = section.settings.layout_type %}
{% else %}
  {% assign effective_layout = 'center' %}
{% endif %}

{% comment %} === BUILD SPACING CLASSES === {% endcomment %}
{% assign spacing_classes = '' %}
{% if section.settings.margin_top != 'none' %}{% assign spacing_classes = spacing_classes | append: ' mt-' | append: section.settings.margin_top %}{% endif %}
{% if section.settings.margin_bottom != 'none' %}{% assign spacing_classes = spacing_classes | append: ' mb-' | append: section.settings.margin_bottom %}{% endif %}
{% if section.settings.padding_top != 'none' %}{% assign spacing_classes = spacing_classes | append: ' pt-' | append: section.settings.padding_top %}{% endif %}
{% if section.settings.padding_bottom != 'none' %}{% assign spacing_classes = spacing_classes | append: ' pb-' | append: section.settings.padding_bottom %}{% endif %}

{% assign seo_tag = section.settings.html_tag %}
{% assign title_style_class = section.settings.title_style_class %}
{% assign desc_style_class = section.settings.desc_style_class %}
{% assign text_align = section.settings.text_align %}
{% assign btn_style = section.settings.btn_style %}
{% assign btn_2_style = section.settings.btn_2_style %}
{% assign bullet_style = section.settings.bullet_style %}
{% assign has_btn_1 = section.settings.show_btn %}
{% assign has_btn_2 = section.settings.show_btn_2 %}
{% assign has_any_btn = false %}
{% if has_btn_1 or has_btn_2 %}{% assign has_any_btn = true %}{% endif %}

{% comment %} === ALT TEXT FALLBACKS === {% endcomment %}
{% if section.settings.main_img_alt != blank %}
  {% assign main_img_alt = section.settings.main_img_alt %}
{% else %}
  {% assign main_img_alt = section.settings.title_text | default: 'Feature image' %}
{% endif %}

{% if section.settings.icon_img_alt != blank %}
  {% assign icon_img_alt = section.settings.icon_img_alt %}
{% else %}
  {% assign icon_img_alt = 'Icon' %}
{% endif %}

{% comment %} === REUSABLE CONTENT BLOCK === {% endcomment %}
{% capture content_block %}
    {% if section.settings.overline_text != blank %}
        <span class="overline">{{ section.settings.overline_text }}</span>
    {% endif %}

    {% if section.settings.icon_img != blank %}
        <div class="feat-icon">
            <img src="{{ section.settings.icon_img | image_picker_url: 'default' }}" alt="{{ icon_img_alt | escape }}">
        </div>
    {% endif %}

    {% if section.settings.title_text != blank %}
    <{{ seo_tag }} class="dynamic-title{% if title_style_class != blank %} {{ title_style_class }}{% endif %}">{{ section.settings.title_text }}</{{ seo_tag }}>
    {% endif %}

    <div class="desc-richtext{% if bullet_style != 'default' %} bullet-{{ bullet_style }}{% endif %}{% if desc_style_class != blank %} {{ desc_style_class }}{% endif %}">{{ section.settings.desc_richtext }}</div>

    {% if section.settings.list_style == 'badge' %}
        <div class="list-badges">
            {% for block in section.blocks %}
                <span class="badge-item"><span class="badge-dot"></span>{{ block.settings.list_text }}</span>
            {% endfor %}
        </div>
    {% endif %}

    {% if has_any_btn %}
        <div class="cta-wrap{% if has_btn_2 %} cta-wrap-dual{% endif %}">
            <div class="cta-buttons-row">
                {% if has_btn_1 %}
                    <a href="{{ section.settings.btn_url }}" 
                       class="btn btn-{{ btn_style }}"
                       {% if section.settings.btn_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                        {{ section.settings.btn_text }}
                    </a>
                {% endif %}
                
                {% if has_btn_2 %}
                    <a href="{{ section.settings.btn_2_url }}" 
                       class="btn btn-{{ btn_2_style }}"
                       {% if section.settings.btn_2_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                        {{ section.settings.btn_2_text }}
                    </a>
                {% endif %}
            </div>
            {% if section.settings.date_hint != blank %}
                <p class="button-footer-hint">{{ section.settings.date_hint }}</p>
            {% endif %}
        </div>
    {% endif %}
    
    {% if section.settings.show_text_link and section.settings.text_link_text != blank %}
        <div class="pm-text-link-icon-wrap" style="--text-link-color: {{ section.settings.text_link_color }};">
            <a href="{{ section.settings.text_link_url }}"
               class="pm-text-link-icon"
               {% if section.settings.text_link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                {{ section.settings.text_link_text }}
                <svg viewBox="0 0 14 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8.33333 10L7.16667 8.79167L10.125 5.83333H0V4.16667H10.125L7.16667 1.20833L8.33333 0L13.3333 5L8.33333 10Z" fill="currentColor"/>
                </svg>
            </a>
        </div>
    {% endif %}
{% endcapture %}

<style>
    /* ============================================
       SCOPED CSS — section-specific only
       ============================================ */
    .custom-master-{{ section.id }} {
        background: {{ section.settings.bg_color }};
        box-sizing: border-box;
    }

    .custom-master-{{ section.id }} * {
        box-sizing: border-box;
    }

    /* === CONTAINER === */
    .custom-master-{{ section.id }} .container {
        margin: 0 auto;
        padding: 0 32px;
    }

    /* === TEXT ALIGNMENT === */
    .custom-master-{{ section.id }} .text-align-left { text-align: left; }
    .custom-master-{{ section.id }} .text-align-center { text-align: center; }
    .custom-master-{{ section.id }} .text-align-right { text-align: right; }

    .custom-master-{{ section.id }} .text-align-center .overline,
    .custom-master-{{ section.id }} .text-align-center .list-badges,
    .custom-master-{{ section.id }} .text-align-center .cta-buttons-row { justify-content: center; }
    .custom-master-{{ section.id }} .text-align-center .feat-icon { display: inline-block; }

    .custom-master-{{ section.id }} .text-align-right .overline,
    .custom-master-{{ section.id }} .text-align-right .list-badges,
    .custom-master-{{ section.id }} .text-align-right .cta-buttons-row { justify-content: flex-end; }

    /* === TYPOGRAPHY === */
    .custom-master-{{ section.id }} .dynamic-title {
        color: {{ section.settings.title_color }};
        {% if section.settings.title_mb != blank %}margin: 0 0 {{ section.settings.title_mb }}px;{% endif %}
    }
    .custom-master-{{ section.id }} .desc-richtext {
        color: {{ section.settings.desc_color }};
        margin-bottom: 25px;
    }
    .custom-master-{{ section.id }} .desc-richtext p { margin-bottom: 8px; }
    .custom-master-{{ section.id }} .desc-richtext strong,
    .custom-master-{{ section.id }} .desc-richtext b { color: {{ section.settings.title_color }}; }

    .custom-master-{{ section.id }} .overline {
        color: {{ section.settings.overline_color }};
        line-height: 1.14em;
        font-weight: 600;
        margin-bottom: 8px;
        display: inline-flex;
        align-items: center;
        font-size: 14px;
    }

    /* === LAYOUT: NO IMAGE (text-only) === */
    .custom-master-{{ section.id }} .layout-no-image { width: 100%; }
    .custom-master-{{ section.id }} .layout-no-image.text-align-center { margin: 0 auto; }
    .custom-master-{{ section.id }} .layout-no-image.text-align-center .cta-wrap { margin-inline: auto; }
    {% if section.settings.content_max_width != blank %}
    .custom-master-{{ section.id }} .layout-no-image { max-width: {{ section.settings.content_max_width }}px; }
    .custom-master-{{ section.id }} .layout-no-image.text-align-right { margin-left: auto; }
    {% endif %}

    /* === LAYOUT: SIDE-BY-SIDE === */
    .custom-master-{{ section.id }} .layout-side {
        display: flex;
        flex-wrap: wrap;
        align-items: {{ section.settings.vertical_align }};
        gap: 64px;
    }
    .custom-master-{{ section.id }} .layout-side.image-left { flex-direction: row-reverse; }
    .custom-master-{{ section.id }} .flex-content,
    .custom-master-{{ section.id }} .flex-img { flex: 1; }
    .custom-master-{{ section.id }} .flex-img { display: flex; }
    .custom-master-{{ section.id }} .main-image {
        width: 100%;
        {% if section.settings.vertical_align == 'stretch' %}height: 100%;{% else %}height: auto;{% endif %}
        object-fit: cover;
        border-radius: 12px;
    }

    /* === ICONS === */
    .custom-master-{{ section.id }} .feat-icon { margin-bottom: 24px; }
    .custom-master-{{ section.id }} .feat-icon img {
        max-width: 48px;
        max-height: 48px;
        height: auto;
    }

    /* === BADGE LIST === */
    .custom-master-{{ section.id }} .list-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin: 32px 0;
    }
    .custom-master-{{ section.id }} .badge-item {
        background: #F1FCF9;
        border: 1px solid #A1EEDE;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 500;
        line-height: 1.2;
        color: #184946;
        display: flex;
        align-items: center;
        gap: 4px;
    }
    .custom-master-{{ section.id }} .badge-dot {
        width: 6px;
        height: 6px;
        background: #22AA9A;
        border-radius: 50%;
    }

    /* === CTA WRAPPER === */
    .custom-master-{{ section.id }} .cta-wrap {
        width: 100%;
        max-width: 364px;
    }
    .custom-master-{{ section.id }} .cta-wrap.cta-wrap-dual {
        max-width: 600px;
    }

    /* === CTA BUTTONS ROW === */
    .custom-master-{{ section.id }} .cta-buttons-row {
        display: flex;
        flex-wrap: wrap;
        gap: 33px;
        width: 100%;
    }
    .custom-master-{{ section.id }} .cta-buttons-row .btn {
        flex: 1;
        min-width: 0;
        margin: 0;
    }

    .custom-master-{{ section.id }} .button-footer-hint {
        text-align: center;
    }

    /* ============================================
       RESPONSIVE
       ============================================ */
    @media (max-width: 600px) {
        .custom-master-{{ section.id }} .layout-side,
        .custom-master-{{ section.id }} .layout-side.image-left {
            flex-direction: column-reverse;
            gap: 32px;
        }
        .custom-master-{{ section.id }} .flex-img,
        .custom-master-{{ section.id }} .flex-content { width: 100% !important; }
        .custom-master-{{ section.id }} .layout-no-image { max-width: 100% !important; }
        .custom-master-{{ section.id }} .main-image { height: auto !important; }

        .custom-master-{{ section.id }} .cta-buttons-row { flex-direction: column; gap: 12px }
        .custom-master-{{ section.id }} .cta-buttons-row .btn { width: 100%; }
    }

    /* ============================================
       CUSTOM STYLES — WEBINAR LP
       (kept untouched for backward-compat)
       ============================================ */
    .custom-master-{{ section.id }}.section-meet-bb .container,
    .custom-master-{{ section.id }}.section-how-to .container,
    .custom-master-{{ section.id }}.section-learn .container {
        width: 100%;
        max-width: 1216px;
        margin-inline: auto;
        padding: 0;
    }

    .custom-master-1776974186850 .dynamic-title {
        position: relative;
        z-index: 1;
    }
    .custom-master-1776974186850 .dynamic-title::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
