        background-size: 100% 100%;
        background-repeat: no-repeat;
        z-index: -1;
        pointer-events: none;
    }

    .custom-master-{{ section.id }}.section-learn .desc-richtext {
        margin-bottom: 0;
        width: 100%;
        max-width: 520px;
    }
    .custom-master-{{ section.id }}.section-how-to .desc-richtext p,
    .custom-master-{{ section.id }}.section-learn .desc-richtext p {
        margin-bottom: 0;
        line-height: 1.4em;
    }
    .custom-master-{{ section.id }}.section-meet-bb .button-footer-hint,
    .custom-master-{{ section.id }}.section-how-to .button-footer-hint {
        font-size: 14px;
        line-height: 1.14em;
    }
    .custom-master-{{ section.id }}.section-meet-bb .desc-richtext p {
        font-size: 16px;
        line-height: 1.4em;
    }
    .custom-master-{{ section.id }}.section-meet-bb .desc-richtext p:last-child { margin-bottom: 0; }

    @media (max-width: 1400px) {
        .custom-master-{{ section.id }} .container { padding-inline: 32px !important; }
    }

    @media (max-width: 1024px) {
        .custom-master-1776974186850 .dynamic-title {
            max-width: 768px;
            margin-inline: auto;
        }
        .custom-master-1776974186850 .dynamic-title::after { max-height: 24px; }

        .custom-master-{{ section.id }}.section-meet-bb .container,
        .custom-master-{{ section.id }}.section-how-to .container,
        .custom-master-{{ section.id }}.section-learn .container {
            padding-inline: 32px;
        }
        .custom-master-{{ section.id }}.section-meet-bb .layout-side.image-left,
        .custom-master-{{ section.id }}.section-how-to .layout-side.image-left {
            flex-direction: column-reverse;
            gap: 32px;
        }
        .custom-master-{{ section.id }}.section-meet-bb .layout-side.image-left .flex-img,
        .custom-master-{{ section.id }}.section-how-to .layout-side.image-left .flex-img {
            max-width: 576px;
        }
        .custom-master-{{ section.id }}.section-how-to .feat-icon { margin-bottom: 15px; }
        .custom-master-{{ section.id }}.section-how-to .feat-icon img {
            max-width: 40px;
            max-height: 40px;
        }
        .custom-master-{{ section.id }}.section-how-to .dynamic-title {
            width: 100%;
            max-width: 530px;
        }
        .custom-master-{{ section.id }}.section-meet-bb .desc-richtext { margin-bottom: 32px; }
        .custom-master-1777249501331 .flex-img { display: none; }
        .custom-master-1777249501331 .desc-richtext.bullet-checklist-large > ul {margin: 0;}
    }

    @media (max-width: 710px) {
        .custom-master-1776974186850 .dynamic-title::after { content: none; }
    }

    @media (max-width: 600px) {
        .custom-master-{{ section.id }} .container { padding-inline: 16px !important; }

        .custom-master-1776974186850 .dynamic-title { margin: 0 0 24px; }
        .custom-master-1776974186850 .desc-richtext { margin-bottom: 20px; }
        .custom-master-1776974186850 .list-badges { margin: 0 0 32px; }

        .custom-master-1776974781380.section-learn .container { padding-bottom: 0; }

        .custom-master-1776974857642.section-meet-bb .layout-side.image-left,
        .custom-master-1776974857642.section-how-to .layout-side.image-left { gap: 24px; }
        .custom-master-1776974857642 .desc-richtext { margin-bottom: 20px; }

        .desc-richtext.bullet-checklist ul,
        .desc-richtext.bullet-checklist-large ul { margin: 8px 0 0 !important; }
        .desc-richtext.bullet-checklist ul li,
        .desc-richtext.bullet-checklist-large ul li { margin-bottom: 11px !important; }

        .custom-master-1776975909738 .dynamic-title { font-size: 36px; }
        .custom-master-1777249501331 .desc-richtext.bullet-checklist-large > ul {margin-top: 0 !important; padding: 0;}
        
        .custom-master-{{ section.id }} .text-link-secondary { text-align: center }
        .custom-master-{{ section.id }} .text-link-secondary svg { display: none }
    }
    
    @media screen and (max-width: 1024px) {
        .custom-master-{{ section.id }} .layout-side,
        .custom-master-{{ section.id }} .layout-side.image-left {
            flex-direction: column-reverse !important;
            align-items: start !important;
            gap: 32px !important;
        }
    }
    
     /* ============================================
    CUSTOM STYLES — AUDIOBOOK
    ============================================ */
    .custom-master-1777249489155 .desc-richtext {
        width: 100%;
        max-width: 600px;
    }
    
    @media (max-width: 1024px) {
        .custom-master-1777249489155 .desc-richtext {
            display: none;
        }
        
        .custom-master-1777249489155 .dynamic-title {
            margin: 0;
        }
    }
</style>

<div class="custom-master-{{ section.id }}{{ spacing_classes }}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}">
    <div class="container">

        {% if effective_layout == 'center' %}
            {% comment %} ===== TEXT-ONLY LAYOUT ===== {% endcomment %}
            <div class="layout-no-image text-align-{{ text_align }}">
                {{ content_block }}
            </div>

        {% else %}
            {% comment %} ===== SIDE-BY-SIDE LAYOUT ===== {% endcomment %}
            <div class="layout-side {% if effective_layout == 'image_left' %}image-left{% endif %}">
                <div class="flex-content text-align-{{ text_align }}">
                    {{ content_block }}
                </div>
                <div class="flex-img">
                    <img src="{{ section.settings.main_img | image_picker_url: 'default' }}" alt="{{ main_img_alt | escape }}" class="main-image" loading="lazy">
                </div>
            </div>
        {% endif %}

    </div>
</div>

{% schema %}
{
  "name": "Master Hero / Features",
  "elements": [
    {
      "type": "header",
      "content": "Main Title"
    },
    {
      "type": "text",
      "id": "title_text",
      "label": "Main Title",
      "default": "Turn the challenge of 'kids these days' into your competitive advantage"
    },
    {
      "type": "select",
      "id": "html_tag",
      "label": "Title HTML Tag (SEO)",
      "default": "h1",
      "options": [
        { "label": "Heading 1 (H1)", "value": "h1" },
        { "label": "Heading 2 (H2)", "value": "h2" },
        { "label": "Heading 3 (H3)", "value": "h3" },
        { "label": "Heading 4 (H4)", "value": "h4" }
      ]
    },
    {
      "type": "select",
      "id": "title_style_class",
      "label": "Title Visual Style",
      "info": "Adds a class to style the heading independent of its SEO tag. Leave Default to inherit.",
      "default": "",
      "options": [
        { "label": "Default (No Extra Class)", "value": "" },
        { "label": "Heading 1 Style (.h1)", "value": "h1" },
        { "label": "Heading 2 Style (.h2)", "value": "h2" },
        { "label": "Heading 3 Style (.h3)", "value": "h3" },
        { "label": "Heading 4 Style (.h4)", "value": "h4" },
        { "label": "Text XL (.text-xl)", "value": "text-xl" },
        { "label": "Text Large (.text-lg)", "value": "text-lg" },
        { "label": "Text Medium (.text-md)", "value": "text-md" },
        { "label": "Text Small (.text-sm)", "value": "text-sm" }
      ]
    },
    {
      "type": "text",
      "id": "title_mb",
      "label": "Title Spacing Bottom (px)",
      "info": "Space below the title. Leave blank to use the default from your global styles.",
      "default": ""
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "info": "Applies to icon, subheading, title, description, list, and button.",
      "default": "left",
      "options": [
        { "label": "Left", "value": "left" },
        { "label": "Center", "value": "center" },
        { "label": "Right", "value": "right" }
      ]
    },

    {
      "type": "header",
      "content": "Subheading"
    },
    {
      "type": "text",
      "id": "overline_text",
      "label": "Subheading Text",
      "default": "",
      "info": "Small text above the title. Leave blank to hide."
    },

    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "image_picker",
      "id": "icon_img",
      "label": "Upload Icon",
      "info": "Upload an SVG or PNG. Shown large above the title."
    },
    {
      "type": "text",
      "id": "icon_img_alt",
      "label": "Icon Alt Text",
      "info": "Describe the icon for accessibility & SEO. Leave blank to default to 'Icon'.",
      "default": ""
    },

    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "rich_text",
      "id": "desc_richtext",
      "label": "Description Paragraph",
      "default": "<p>Learn how to increase ownership, engagement, and accountability without lowering your standards or expectations.</p>"
    },
    {
