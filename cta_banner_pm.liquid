92 69.5885C144.371 69.6028 144.422 69.5668 144.557 69.3971C144.676 69.2471 144.824 69.0391 144.998 68.774C145.346 68.2452 145.773 67.5279 146.249 66.6786C147.198 64.9823 148.318 62.7958 149.339 60.6165C150.362 58.433 151.276 56.2805 151.821 54.6465C152.096 53.8219 152.263 53.1723 152.315 52.7325C152.342 52.5064 152.33 52.3978 152.324 52.3694C152.318 52.3443 152.362 52.549 152.609 52.64L152.885 51.8892Z' fill='%2319887D'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-size: contain;
    }

    /* === RESPONSIVE === */
    @media screen and (max-width: 1024px) {
        .pm-cta-banner-{{ section.id }} .image-wrap {
            margin-bottom: 32px;
        }
        
        .pm-cta-banner-{{ section.id }} .content-wrap.layout-split {
            grid-template-columns: 1fr;
            gap: 20px;
        }
        
        .pm-cta-banner-{{ section.id }}.banner-order .split-left::after {
            content: none;
        }
    }
    
    @media screen and (max-width: 600px) {
        .pm-cta-banner-{{ section.id }} .container {
            padding-inline: 16px;
        }
        
        .pm-cta-banner-{{ section.id }} .banner-img {
            min-height: 160px;
        }
        
        .pm-cta-banner-{{ section.id }} .btn-group {
            flex-direction: column;
            align-items: start;
            gap: 12px
        }
    }
</style>

<div class="pm-cta-banner-{{ section.id }}{{ spacing_classes }}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}">
    <div class="container">

        {% if section.settings.banner_img != blank %}
        <div class="image-wrap">
            <img src="{{ section.settings.banner_img | image_picker_url: 'default' }}" alt="{{ section.settings.img_alt | escape }}" class="banner-img"loading="lazy">
        </div>
        {% endif %}

        {% assign sec_tag = section.settings.section_title_tag %}
        {% assign sec_style = section.settings.section_title_style_class %}

        {% if layout == 'split' %}
            {% comment %} ===== 40 / 60 SPLIT LAYOUT ===== {% endcomment %}
            <div class="content-wrap layout-split">
                <div class="split-left">
                    {% if section.settings.section_title != blank %}
                        <{{ sec_tag }} class="dynamic-title{% if sec_style != blank %} {{ sec_style }}{% endif %}">{{ section.settings.section_title }}</{{ sec_tag }}>
                    {% endif %}
                    {% if section.settings.subheading_text != blank %}
                        <p class="subheading-text">{{ section.settings.subheading_text }}</p>
                    {% endif %}
                </div>

                <div class="split-right">
                    {% if section.settings.desc_text != blank %}
                        <div class="desc-text">{{ section.settings.desc_text }}</div>
                    {% endif %}

                    {% if section.settings.show_btn or section.settings.show_btn_2 %}
                        <div class="btn-group">
                            {% if section.settings.show_btn %}
                                <a href="{{ section.settings.btn_url }}" 
                                   class="btn btn-{{ section.settings.btn_style }}"
                                   {% if section.settings.btn_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                                    {{ section.settings.btn_text }}
                                </a>
                            {% endif %}
                            
                            {% if section.settings.show_btn_2 %}
                                <a href="{{ section.settings.btn_url_2 }}" 
                                   class="btn btn-{{ section.settings.btn_style_2 }}"
                                   {% if section.settings.btn_2_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                                    {{ section.settings.btn_text_2 }}
                                </a>
                            {% endif %}
                        </div>
                    {% endif %}
                    
                    {% if section.settings.show_text_link and section.settings.text_link_text != blank %}
                        <div class="pm-text-link-icon-wrap" style="--text-link-color: {{ section.settings.text_link_color }};">
                            <a href="{{ section.settings.text_link_url }}"
                               class="pm-text-link-icon"
                               {% if section.settings.text_link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                                {{ section.settings.text_link_text }}
                                <svg viewBox="0 0 14 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M8.33333 10L7.16667 8.79167L10.125 5.83333H0V4.16667H10.125L7.16667 1.20833L8.33333 0L13.3333 5L8.33333 10Z" fill="currentColor"/>
                                </svg>
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>

        {% else %}
            {% comment %} ===== CENTERED (default) LAYOUT ===== {% endcomment %}
            <div class="content-wrap layout-centered">
                {% if section.settings.section_title != blank %}
                    <{{ sec_tag }} class="dynamic-title{% if sec_style != blank %} {{ sec_style }}{% endif %}">{{ section.settings.section_title }}</{{ sec_tag }}>
                {% endif %}

                {% if section.settings.subheading_text != blank %}
                    <p class="subheading-text">{{ section.settings.subheading_text }}</p>
                {% endif %}

                {% if section.settings.desc_text != blank %}
                    <div class="desc-text">{{ section.settings.desc_text }}</div>
                {% endif %}

                {% if section.settings.show_btn or section.settings.show_btn_2 %}
                    <div class="btn-group">
                        {% if section.settings.show_btn %}
                            <a href="{{ section.settings.btn_url }}" 
                               class="btn btn-{{ section.settings.btn_style }}"
                               {% if section.settings.btn_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                                {{ section.settings.btn_text }}
                            </a>
                        {% endif %}
                        
                        {% if section.settings.show_btn_2 %}
                            <a href="{{ section.settings.btn_url_2 }}" 
                               class="btn btn-{{ section.settings.btn_style_2 }}"
                               {% if section.settings.btn_2_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                                {{ section.settings.btn_text_2 }}
                            </a>
                        {% endif %}
                    </div>
                {% endif %}
                
                {% if section.settings.show_text_link and section.settings.text_link_text != blank %}
                    <div class="pm-text-link-icon-wrap" style="--text-link-color: {{ section.settings.text_link_color }};">
                        <a href="{{ section.settings.text_link_url }}"
                           class="pm-text-link-icon"
                           {% if section.settings.text_link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                            {{ section.settings.text_link_text }}
                            <svg viewBox="0 0 14 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M8.33333 10L7.16667 8.79167L10.125 5.83333H0V4.16667H10.125L7.16667 1.20833L8.33333 0L13.3333 5L8.33333 10Z" fill="currentColor"/>
                            </svg>
                        </a>
                    </div>
                {% endif %}
            </div>
        {% endif %}

    </div>
</div>

{% schema %}
{
  "name": "CTA Banner - PM",
  "elements": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "content_layout",
      "label": "Content Layout",
      "info": "Centered = stacked under image. Split 40/60 = title+subheading on left, description+button on right.",
      "default": "centered",
      "options": [
        { "label": "Centered (Default)", "value": "centered" },
        { "label": "Split 40 / 60", "value": "split" }
      ]
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#F4FAF8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#19887D"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description Text Color",
      "default": "#444444"
    },
    {
      "type": "header",
      "content": "Banner Image"
    },
    {
      "type": "image_picker",
      "id": "banner_img",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "img_alt",
      "label": "Image Alt Text (SEO)",
      "default": "Book bundle showcase"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Main Heading",
      "default": "Ready for a better way to coach the conversation?"
    },
    {
      "type": "select",
      "id": "section_title_tag",
      "label": "Heading HTML Tag (SEO)",
      "default": "h2",
      "options": [
        { "label": "Heading 1 (H1)", "value": "h1" },
        { "label": "Heading 2 (H2)", "value": "h2" },
        { "label": "Heading 3 (H3)", "value": "h3" }
      ]
    },
    {
      "type": "select",
      "id": "section_title_style_class",
      "label": "Heading Visual Style",
      "default": "h2",
      "options": [
        { "label": "H1 Style", "value": "h1" },
        { "label": "H2 Style", "value": "h2" },
        { "label": "H3 Style", "value": "h3" }
      ]
    },
    {
      "type": "text",
      "id": "subheading_text",
      "label": "Subheading (Optional)",
      "default": "",
      "info": "Small line of text shown below the heading. Leave blank to hide."
    },
    {
      "type": "rich_text",
      "id": "desc_text",
      "label": "Description",
      "default": "<p>Get your copy of Kids These Days and start using practical communication tools that help your message land.</p>"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "checkbox",
      "id": "show_btn",
      "label": "Show Primary Button?",
      "default": "true"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Buy Kids These Days"
    },
    {
      "type": "text",
      "id": "btn_url",
      "label": "Button Link",
      "default": "#"
    },
    {
      "type": "checkbox",
      "id": "btn_new_tab",
      "label": "Open in New Tab?",
      "default": "false"
    },
    {
      "type": "select",
      "id": "btn_style",
      "label": "Button Style",
      "default": "primary",
      "options": [
        { "label": "Primary", "value": "primary" },
        { "label": "Secondary", "value": "secondary" }
      ]
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "checkbox",
      "id": "show_btn_2",
      "label": "Show Secondary Button?",
      "default": "false"
    },
    {
      "type": "text",
      "id": "btn_text_2",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "text",
      "id": "btn_url_2",
      "label": "Button Link",
      "default": "#"
    },
    {
      "type": "checkbox",
      "id": "btn_2_new_tab",
      "label": "Open in New Tab?",
      "default": "false"
    },
    {
      "type": "select",
      "id": "btn_style_2",
      "label": "Button Style",
      "default": "secondary",
      "options": [
        { "label": "Primary", "value": "primary" },
        { "label": "Secondary", "value": "secondary" }
      ]
    },
    {
      "type": "header",
      "content": "Text Link (Below Button)"
    },
    {
      "type": "checkbox",
      "id": "show_text_link",
      "label": "Show Text Link?",
      "default": "false"
    },
    {
      "type": "text",
      "id": "text_link_text",
      "label": "Text Link Content",
      "default": "Or read it — available on Audible, Spotify, and Amazon."
    },
    {
      "type": "text",
      "id": "text_link_url",
      "label": "Text Link URL",
      "default": "#"
    },
    {
      "type": "checkbox",
      "id": "text_link_new_tab",
      "label": "Open in New Tab?",
      "default": "false"
    },
    {
      "type": "color",
      "id": "text_link_color",
      "label": "Text Link Color",
      "default": "#535862"
    },
