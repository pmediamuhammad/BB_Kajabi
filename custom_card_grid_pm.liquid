<!-- Start Version 1.8.4 -->
{% comment %} === BUILD SPACING CLASSES === {% endcomment %}
{% assign spacing_classes = '' %}
{% if section.settings.margin_top != 'none' %}{% assign spacing_classes = spacing_classes | append: ' mt-' | append: section.settings.margin_top %}{% endif %}
{% if section.settings.margin_bottom != 'none' %}{% assign spacing_classes = spacing_classes | append: ' mb-' | append: section.settings.margin_bottom %}{% endif %}
{% if section.settings.padding_top != 'none' %}{% assign spacing_classes = spacing_classes | append: ' pt-' | append: section.settings.padding_top %}{% endif %}
{% if section.settings.padding_bottom != 'none' %}{% assign spacing_classes = spacing_classes | append: ' pb-' | append: section.settings.padding_bottom %}{% endif %}

{% comment %} === COLUMN COUNT: ceil(card_count / rows) === {% endcomment %}
{% assign card_count = section.blocks | size %}
{% assign rows = section.settings.rows | plus: 0 %}
{% if rows < 1 %}{% assign rows = 1 %}{% endif %}
{% assign cols = card_count | divided_by: rows %}
{% assign remainder = card_count | modulo: rows %}
{% if remainder > 0 %}{% assign cols = cols | plus: 1 %}{% endif %}
{% if cols < 1 %}{% assign cols = 1 %}{% endif %}

{% assign icon_position = section.settings.icon_position %}
{% assign card_direction = section.settings.card_direction %}
{% assign text_align = section.settings.text_align %}
{% assign card_text_align = section.settings.card_text_align %}
{% assign card_text_position = section.settings.card_text_position %}

<style>
    /* === SCOPED CSS === */
    .pm-card-grid-{{ section.id }} {
        background: {{ section.settings.bg_color }};
        box-sizing: border-box;
    }

    .pm-card-grid-{{ section.id }} * {
        box-sizing: border-box;
    }

    /* === CONTAINER === */
    .pm-card-grid-{{ section.id }} .container {
        margin: 0 auto;
        padding: 0;
    }

    /* === GRID === */
    .pm-card-grid-{{ section.id }} .card-grid {
        display: grid;
        grid-template-columns: repeat({{ cols }}, 1fr);
        gap: {{ section.settings.gap_row }}px {{ section.settings.gap_col }}px;
        align-items: {% if section.settings.card_height == 'content' %}start{% else %}stretch{% endif %};
    }

    /* === CARD === */
    .pm-card-grid-{{ section.id }} .pm-card {
        background: {{ section.settings.card_bg_color }};
        border: 2px solid {{ section.settings.card_border_color }};
        border-radius: var(--pm-card-radius);
        padding: {{ section.settings.card_padding }}px;
        position: relative;
        display: flex;
        {% if card_direction == 'row' %}
        flex-direction: row;
        align-items: start;
        gap: 12px;
        {% else %}
        flex-direction: column;
        {% endif %}
        {% if icon_position == 'middle_top_floating' %}
        margin-top: 28px;
        {% endif %}
    }

    /* === CARD ICON: LEFT TOP (default, column) === */
    .pm-card-grid-{{ section.id }} .pm-card.card-direction-column .card-icon {
        margin-bottom: 22px;
    }
    .pm-card-grid-{{ section.id }} .pm-card .card-icon img {
        max-width: 40px;
        max-height: 40px;
        height: auto;
    }

    /* === CARD DIRECTION: ROW === */
    .pm-card-grid-{{ section.id }} .pm-card.card-direction-row .card-icon {
        padding: 5px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0;
    }
    .pm-card-grid-{{ section.id }} .pm-card.card-direction-row .card-icon img {
        display: block;
    }
    .pm-card-grid-{{ section.id }} .pm-card.card-direction-row .card-content {
        flex: 1;
        min-width: 0;
    }

    /* === CARD ICON: MIDDLE TOP FLOATING === */
    .pm-card-grid-{{ section.id }} .pm-card.icon-middle-top-floating .card-icon {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translate(-50%, -50%);
        background: {{ section.settings.card_bg_color }};
        border-radius: 50%;
        line-height: 0;
        margin-bottom: 0;
    }
    .pm-card-grid-{{ section.id }} .pm-card.icon-middle-top-floating .card-icon img {
        width: 32px;
        height: 32px;
        display: block;
    }
    .pm-card-grid-{{ section.id }} .pm-card.icon-middle-top-floating .card-content {
        padding-top: 16px;
    }

    /* === SECTION HEADER === */
    .pm-card-grid-{{ section.id }} .card-grid-header {
        margin-bottom: 32px;
    }
    .pm-card-grid-{{ section.id }} .section-desc {
        color: {{ section.settings.section_desc_color }};
        margin: 0 0 0;
        max-width: 720px;
    }
    .pm-card-grid-{{ section.id }} .card-grid-header.align-center .section-desc {
        margin-left: auto;
        margin-right: auto;
    }
    .pm-card-grid-{{ section.id }} .card-grid-header.align-right .section-desc {
        margin-left: auto;
    }

    /* === SECTION HEADING ALIGNMENT === */
    .pm-card-grid-{{ section.id }} .card-grid-header.align-left { text-align: left; }
    .pm-card-grid-{{ section.id }} .card-grid-header.align-center { text-align: center; }
    .pm-card-grid-{{ section.id }} .card-grid-header.align-right { text-align: right; }

    /* === CARD TEXT ALIGNMENT === */
    .pm-card-grid-{{ section.id }} .pm-card.card-align-left .card-content { text-align: left; }
    .pm-card-grid-{{ section.id }} .pm-card.card-align-center .card-content { text-align: center; }
    .pm-card-grid-{{ section.id }} .pm-card.card-align-right .card-content { text-align: right; }

    /* === CARD TEXT POSITION: BOTTOM === */
    .pm-card-grid-{{ section.id }} .pm-card.card-direction-column.text-position-bottom .card-content {
        margin-top: auto;
    }

    {% if section.settings.card_content_max_width != blank %}
    /* === CARD CONTENT MAX WIDTH === */
    .pm-card-grid-{{ section.id }} .pm-card.card-direction-column .card-content {
        max-width: {{ section.settings.card_content_max_width }}px;
    }
    .pm-card-grid-{{ section.id }} .pm-card.card-align-center .card-content {
        margin-left: auto;
        margin-right: auto;
    }
    .pm-card-grid-{{ section.id }} .pm-card.card-align-right .card-content {
        margin-left: auto;
    }
    {% endif %}

    /* === CARD CONTENT === */
    .pm-card-grid-{{ section.id }} .card-subtitle {
        color: {{ section.settings.card_subtitle_color }};
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 0 0 8px;
        display: block;
    }
    .pm-card-grid-{{ section.id }} .card-title {
        color: {{ section.settings.card_title_color }};
        {% if section.settings.card_title_mb != blank %}
        margin: 0 0 {{ section.settings.card_title_mb }}px;
        {% endif %}
    }
    .pm-card-grid-{{ section.id }} .card-cta-wrap {
        margin-top: auto;
        padding-top: 32px;
    }
    
    /* === MODULE: PLATFORM BUTTONS === */
    .pm-card-grid-{{ section.id }} .platform-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 32px;
    }
    .pm-card-grid-{{ section.id }} .platform-btn {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        background: {{ section.settings.platform_bg_color }};
        border-radius: 16px;
        padding: 15px 20px;
        text-decoration: none;
        transition: .3s;
    }
    .pm-card-grid-{{ section.id }} .platform-btn:hover {
        transform: scale(1.025);
    }
    .pm-card-grid-{{ section.id }} .platform-label {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        color: #fff;
        font-size: 14px;
        font-weight: 600;
        white-space: nowrap;
    }
    .pm-card-grid-{{ section.id }} .platform-logo-img {
        max-height: 30px;
        width: auto;
        flex-shrink: 0;
    }

    /* === MODULE: STEP FORM (Kajabi native) === */
    .pm-card-grid-{{ section.id }} .form-wrapper {
        text-align: left;
        margin-top: 32px;
    }

    /* === MODULE: SOCIAL ICONS === */
    .pm-card-grid-{{ section.id }} .card-desc {
        margin: 10px 0 0;
        line-height: 1.4;
    }
    .pm-card-grid-{{ section.id }} .social-list {
        display: flex;
        align-items: center;
        gap: 32px;
        margin-top: 30px;
    }
    .pm-card-grid-{{ section.id }} .social-list a {
        transition: .3s;
    }
    .pm-card-grid-{{ section.id }} .social-list a:hover {
        transform: scale(1.1);
    }
    .pm-card-grid-{{ section.id }} .card-align-center .social-list { justify-content: center; }
    .pm-card-grid-{{ section.id }} .card-align-right .social-list { justify-content: flex-end; }
    .pm-card-grid-{{ section.id }} .social-list a { display: inline-flex; line-height: 0; }
    .pm-card-grid-{{ section.id }} .social-list svg { width: 32px; height: 32px; }

    /* === RESPONSIVE TABLET (1 column) === */
    @media (max-width: 1024px) {
        .pm-card-grid-{{ section.id }} .card-grid {
            grid-template-columns: 1fr;
        }
    }

    /* === CUSTOM STYLE FOR WEBINAR LP === */
    .pm-card-grid-{{ section.id }}.section-tired .container,
    .pm-card-grid-{{ section.id }}.section-then .container {
        width: 100%;
        max-width: 1216px;
        margin-inline: auto;
        padding: 0;
    }

    .pm-card-grid-{{ section.id }}.section-good-coach .container {
        width: 100%;
        max-width: 1280px;
        margin-inline: auto;
        padding: 0;
    }

    .pm-card-grid-{{ section.id }}.section-tired .card-grid-header {
        margin-bottom: 40px;
    }

    .pm-card-grid-{{ section.id }}.section-tired .dynamic-title {
        width: 100%;
        max-width: 600px;
    }

    .pm-card-grid-{{ section.id }}.section-tired .pm-card {
        border: 0;
        border-radius: 24px;
    }

    .pm-card-grid-{{ section.id }}.section-tired .pm-card p {
        line-height: 1.14em;
        font-size: 36px;
    }

    .pm-card-grid-{{ section.id }}.section-then .pm-card .card-title {
        line-height: 1.3em;
    }

    .pm-card-grid-{{ section.id }}.section-then .card-grid-header {
        position: relative;
        display: inline-block;
        margin-bottom: 16px;
    }
    
    .pm-card-grid-{{ section.id }}.section-then .dynamic-title {
        font-size: 26px;
        line-height: 1.14em;
        font-weight: 500;
    }

    .pm-card-grid-{{ section.id }}.section-then .card-grid-header::after {
        content: "";
        position: absolute;
        top: 0;
        right: -130%;
        transform: translateX(50%);
        width: 121px;
        height: 133px;
        background-image: url("data:image/svg+xml;charset=UTF-8,%3Csvg width='121' height='133' viewBox='0 0 121 133' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill-rule='evenodd' clip-rule='evenodd' d='M1.88755 31.2163C41.319 23.6376 89.2638 70.9626 105.642 104.668C105.925 105.246 106.624 105.49 107.202 105.207C107.78 104.925 108.023 104.226 107.741 103.648C90.906 68.9972 41.9817 21.1337 1.44561 28.9254C0.813858 29.0455 0.400036 29.6574 0.521112 30.2919C0.641221 30.9237 1.25302 31.3374 1.88755 31.2163Z' fill='%2319887D' stroke='%2319887D'/%3E%3Cpath fill-rule='evenodd' clip-rule='evenodd' d='M106.386 103.527C104.699 102.362 102.597 100.876 102.354 100.715C95.7587 96.3341 88.8373 93.2113 81.2201 90.9918C80.602 90.8109 79.9529 91.1678 79.772 91.7859C79.5911 92.4039 79.9481 93.0529 80.5661 93.2338C87.9533 95.3837 94.6666 98.4105 101.064 102.661C101.437 102.908 106.158 106.251 107.164 106.855C107.575 107.105 107.885 107.119 107.959 107.115C108.35 107.11 108.601 106.944 108.768 106.78C108.956 106.593 109.19 106.209 109.175 105.628C109.157 105.02 108.811 103.775 108.749 103.453C107.827 98.6009 106.375 93.2655 106.037 88.0663C105.715 83.1082 106.406 78.2681 109.737 74.1586C110.143 73.6587 110.065 72.9221 109.565 72.5161C109.065 72.1101 108.328 72.1886 107.922 72.6886C104.199 77.2838 103.347 82.6758 103.707 88.2165C104.044 93.3849 105.445 98.6845 106.386 103.527Z' fill='%2319887D' stroke='%2319887D'/%3E%3C/svg%3E");
        background-size: contain;
        background-repeat: no-repeat;
        pointer-events: none;
        z-index: 1;
    }

    .pm-card-grid-{{ section.id }}.section-good-coach .pm-card {
        border-radius: 40px;
    }

    .pm-card-grid-{{ section.id }}.section-good-coach .pm-card .card-desc p {
        line-height: 1.14em;
        margin-bottom: 16px;
        color: #484848;
    }

    .pm-card-grid-{{ section.id }}.section-good-coach .pm-card .card-desc p:last-child {
        margin-bottom: 0;
        position: relative;
    }

    .pm-card-grid-{{ section.id }}.section-good-coach .pm-card .card-desc p:last-child span {
        position: relative;
        z-index: 1;
    }

    .pm-card-grid-{{ section.id }}.section-good-coach .pm-card .card-desc p:last-child::after {
        content: "";
        position: absolute;
        bottom: -5px;
        left: 50%;
        transform: translateX(-50%);
