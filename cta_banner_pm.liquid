<!-- Version 1.3.1 -->
{% assign spacing_classes = '' %}
{% if section.settings.margin_top != 'none' %}{% assign spacing_classes = spacing_classes | append: ' mt-' | append: section.settings.margin_top %}{% endif %}
{% if section.settings.margin_bottom != 'none' %}{% assign spacing_classes = spacing_classes | append: ' mb-' | append: section.settings.margin_bottom %}{% endif %}
{% if section.settings.padding_top != 'none' %}{% assign spacing_classes = spacing_classes | append: ' pt-' | append: section.settings.padding_top %}{% endif %}
{% if section.settings.padding_bottom != 'none' %}{% assign spacing_classes = spacing_classes | append: ' pb-' | append: section.settings.padding_bottom %}{% endif %}

{% assign layout = section.settings.content_layout %}

<style>
    /* === SCOPED CSS === */
    .pm-cta-banner-{{ section.id }} {
        background-color: {{ section.settings.bg_color }};
        box-sizing: border-box;
    }

    .pm-cta-banner-{{ section.id }} * {
        box-sizing: border-box;
    }

    .pm-cta-banner-{{ section.id }} .container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 32px;
    }

    /* === IMAGE AREA === */
    .pm-cta-banner-{{ section.id }} .image-wrap {
        margin-bottom: 64px;
        border-radius: 12px;
        overflow: hidden;  
    }

    .pm-cta-banner-{{ section.id }} .banner-img {
        width: 100%;
        height: 100%;
        min-height: 300px;
        display: block;
        object-fit: cover;
        object-position: center;
    }

    /* === TYPOGRAPHY === */
    .pm-cta-banner-{{ section.id }} .dynamic-title {
        color: {{ section.settings.heading_color }};
        margin: 0 0 16px;
    }

    .pm-cta-banner-{{ section.id }} .subheading-text {
        color: {{ section.settings.subheading_color }};
        font-family: var(--pm-font-heading);
        font-size: 16px;
        line-height: 1.4;
        font-weight: 500;
        margin: 0;
    }

    .pm-cta-banner-{{ section.id }} .desc-text {
        color: {{ section.settings.text_color }};
        font-family: var(--pm-font-heading);
        font-size: 16px;
        line-height: 1.4;
        margin: 0 0 32px;
    }
    .pm-cta-banner-{{ section.id }} .desc-text > *:first-child {
        margin-top: 0;
    }
    .pm-cta-banner-{{ section.id }} .desc-text > *:last-child {
        margin-bottom: 0;
    }
    .pm-cta-banner-{{ section.id }} .desc-text p {
        margin: 0 0 16px;
    }
    .pm-cta-banner-{{ section.id }} .desc-text p:has(+ ul) {
        margin: 0 0 6px;
    }
    .pm-cta-banner-{{ section.id }} .desc-text strong,
    .pm-cta-banner-{{ section.id }} .desc-text b {
        color: {{ section.settings.heading_color }};
        font-weight: 700;
    }
    .pm-cta-banner-{{ section.id }} .desc-text ul,
    .pm-cta-banner-{{ section.id }} .desc-text ol {
        margin: 0 0 16px;
        padding-left: 10px;
    }
    .pm-cta-banner-{{ section.id }} .desc-text ul li,
    .pm-cta-banner-{{ section.id }} .desc-text ol li {
        margin-bottom: 0;
    }
    .pm-cta-banner-{{ section.id }} .desc-text ul li::marker {
        content: none;
    }
    .pm-cta-banner-{{ section.id }} .desc-text ul li::before {
        content: "•";
        font-size: 15px;
        margin-right: 10px;
        display: inline-block;
        vertical-align: middle;
    }
    .pm-cta-banner-{{ section.id }} .desc-text a {
        color: var(--pm-primary);
        text-decoration: underline;
    }

    /* === BUTTON GROUP === */
    .pm-cta-banner-{{ section.id }} .btn-group {
        display: flex;
        align-items: center;
        gap: 33px;
        width: 100%;
        max-width: 500px;
    }

    /* === LAYOUT: CENTERED (default) === */
    .pm-cta-banner-{{ section.id }} .content-wrap.layout-centered {
        max-width: 700px;
        margin: 0 auto;
        text-align: center;
    }

    .pm-cta-banner-{{ section.id }} .content-wrap.layout-centered .subheading-text {
        margin: 0 0 16px;
    }

    .pm-cta-banner-{{ section.id }} .content-wrap.layout-centered .btn-group {
        justify-content: center;
    }

    /* === LAYOUT: SPLIT 40/60 === */
    .pm-cta-banner-{{ section.id }} .content-wrap.layout-split {
        display: grid;
        grid-template-columns: 500px 1fr;
        gap: 64px;
        align-items: start;
    }

    .pm-cta-banner-{{ section.id }} .content-wrap.layout-split .split-left {
        text-align: left;
        position: relative;
    }

    .pm-cta-banner-{{ section.id }} .content-wrap.layout-split .split-right {
        text-align: left;
    }

    .pm-cta-banner-{{ section.id }} .content-wrap.layout-split .btn-group {
        justify-content: flex-start;
    }
    
    .pm-cta-banner-{{ section.id }} .content-wrap.layout-split .btn-group .btn {
        margin: 0;
    }
    
    .pm-cta-banner-{{ section.id }}.banner-order .split-left::after {
        content: "";
        position: absolute;
        top: 92%;
        left: 64%;
        width: 100%;
        max-width: 154px;
        height: 74px;
        background-image: url("data:image/svg+xml,%3Csvg width='154' height='74' viewBox='0 0 154 74' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0.825899 1.61525C0.384303 1.62956 0.0147176 1.28318 0.000407479 0.841585C-0.0139027 0.399989 0.332481 0.0304037 0.774077 0.0160935L0.799988 0.815674L0.825899 1.61525ZM151.956 51.8923C152.361 51.7148 152.833 51.8989 153.01 52.3035C153.188 52.7081 153.004 53.18 152.599 53.3575L152.278 52.6249L151.956 51.8923ZM132.784 49.3287C132.347 49.264 132.045 48.8572 132.11 48.4201C132.175 47.9831 132.581 47.6812 133.018 47.746L132.901 48.5374L132.784 49.3287ZM145.288 70.9141C144.922 71.1615 144.425 71.0653 144.177 70.6993C143.93 70.3333 144.026 69.8359 144.392 69.5885L144.84 70.2513L145.288 70.9141ZM0.799988 0.815674C0.774077 0.0160935 0.774379 0.0160838 0.774799 0.0160703C0.775098 0.0160608 0.775637 0.0160436 0.776234 0.0160248C0.777427 0.0159872 0.779095 0.0159353 0.781233 0.0158699C0.78551 0.0157392 0.791669 0.0155548 0.799687 0.0153247C0.815724 0.0148644 0.839195 0.0142207 0.869908 0.0134557C0.931333 0.0119256 1.02173 0.00991039 1.13953 0.00790676C1.37514 0.00389955 1.72043 -6.20955e-05 2.16298 -1.04454e-06C3.04797 0.000121143 4.32239 0.0163309 5.88655 0.0804953C9.01338 0.208762 13.3056 0.528958 17.9635 1.29774C27.22 2.82553 38.1588 6.1612 44.1003 13.5168L43.4779 14.0195L42.8556 14.5222C37.3151 7.66308 26.9149 4.39682 17.7029 2.87638C13.1266 2.12105 8.90221 1.80555 5.82098 1.67915C4.28111 1.61598 3.02864 1.60012 2.16276 1.6C1.72986 1.59994 1.39372 1.60382 1.16674 1.60768C1.05326 1.60961 0.967077 1.61153 0.909749 1.61296C0.881086 1.61367 0.859637 1.61426 0.845597 1.61467C0.838577 1.61487 0.833409 1.61502 0.830118 1.61512C0.828473 1.61517 0.827296 1.61521 0.826592 1.61523C0.82624 1.61524 0.826067 1.61525 0.82589 1.61525C0.825835 1.61526 0.825899 1.61525 0.799988 0.815674ZM43.4779 14.0195L44.1003 13.5168C50.0683 20.9053 49.4871 29.9378 48.896 38.5005C48.2958 47.195 47.6941 55.3788 52.9284 61.859L52.3061 62.3616L51.683