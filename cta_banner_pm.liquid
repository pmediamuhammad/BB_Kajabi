                    <div class="rating-text-wrap">
                        {% if section.settings.main_rating_text != blank %}
                            <p class="main-rating-text">{{ section.settings.main_rating_text }}</p>
                        {% endif %}

                        {% if section.settings.platform_img != blank %}
                            <img src="{{ section.settings.platform_img | image_picker_url: 'default' }}" alt="Platform Logo" class="platform-logo" width="51" height="18">
                        {% endif %}
                    </div>
                </div>

                <div class="content-group-text">
                    {% if section.settings.section_title != blank %}
                        {% assign sec_tag = section.settings.section_title_tag %}
                        {% assign sec_style = section.settings.section_title_style_class %}
                        <{{ sec_tag }} class="dynamic-title{% if sec_style != blank %} {{ sec_style }}{% endif %}">
                            {{ section.settings.section_title | newline_to_br }}
                        </{{ sec_tag }}>
                    {% endif %}

                    {% if section.settings.desc_text != blank %}
                        <p class="desc-text">{{ section.settings.desc_text | newline_to_br }}</p>
                    {% endif %}
                </div>

                <div class="content-group-cta">
                    {% if section.settings.highlight_text != blank %}
                        <p class="highlight-text">{{ section.settings.highlight_text | newline_to_br }}</p>
                    {% endif %}
                
                    {% if section.settings.show_btn or section.settings.show_btn_2 %}
                        <div class="cta-buttons-wrap">
                            {% if section.settings.show_btn %}
                                <a href="{{ section.settings.btn_url }}" 
                                   class="btn btn-{{ section.settings.btn_style }}"
                                   {% if section.settings.btn_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                                    {{ section.settings.btn_text }}
                                </a>
                            {% endif %}
                
                            {% if section.settings.show_btn_2 %}
                                <a href="{{ section.settings.btn_2_url }}" 
                                   class="btn btn-{{ section.settings.btn_2_style }}"
                                   {% if section.settings.btn_2_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                                    {{ section.settings.btn_2_text }}
                                </a>
                            {% endif %}
                        </div>
                    {% endif %}
                    
                    {% if section.settings.show_text_link and section.settings.text_link_text != blank %}
                        <div class="pm-text-link-icon-wrap" style="--text-link-color: {{ section.settings.text_link_color }};">
                            <a href="{{ section.settings.text_link_url }}"
                               class="pm-text-link-icon"
                               {% if section.settings.text_link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                                {{ section.settings.text_link_text }}
                                <svg viewBox="0 0 14 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M8.33333 10L7.16667 8.79167L10.125 5.83333H0V4.16667H10.125L7.16667 1.20833L8.33333 0L13.3333 5L8.33333 10Z" fill="currentColor"/>
                                </svg>
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        
        </div>

    </div>
</div>

